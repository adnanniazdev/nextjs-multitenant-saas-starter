# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# -----------------------------------------------------------------------------
# Connection string to your Neon Postgres database (with RLS enabled)
DATABASE_URL="postgresql://user:password@ep-mock-host.neon.tech/dbname?sslmode=require"

# -----------------------------------------------------------------------------
# Clerk Authentication
# -----------------------------------------------------------------------------
# Publishable key and secret key from Clerk Dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk Webhook Secret (used for verifying user profile sync payloads)
CLERK_WEBHOOK_SECRET="whsec_..."

# -----------------------------------------------------------------------------
# Stripe Billing
# -----------------------------------------------------------------------------
# Secret key and Webhook signing secret from Stripe Dashboard
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID="price_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# -----------------------------------------------------------------------------
# Application Environment Configurations
# -----------------------------------------------------------------------------
# Base domain URL for generating redirect URLs (Stripe checkout, invitations, etc.)
NEXT_PUBLIC_APP_URL="http://lvh.me:3000"
PORT=3000
